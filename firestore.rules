rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isFriend(uid) {
      let id1 = request.auth.uid < uid ? request.auth.uid + '_' + uid : uid + '_' + request.auth.uid;
      return exists(/databases/$(database)/documents/friendships/$(id1))
        && get(/databases/$(database)/documents/friendships/$(id1)).data.status == 'accepted';
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    match /users/{uid}/rankings/{placeId} {
      allow read: if isAuth() && (isOwner(uid) || isFriend(uid));
      allow write: if isOwner(uid);
    }

    match /usernames/{username} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function only
    }

    match /friendships/{docId} {
      allow read: if isAuth()
        && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
      allow create: if isAuth()
        && (request.resource.data.uid1 == request.auth.uid || request.resource.data.uid2 == request.auth.uid)
        && request.resource.data.status == 'pending';
      allow update: if isAuth()
        && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid)
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted';
      allow delete: if isAuth()
        && (resource.data.uid1 == request.auth.uid || resource.data.uid2 == request.auth.uid);
    }

    match /shops/{placeId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Functions only (Admin SDK bypasses rules)
    }

    match /nearbyCache/{geohash} {
      allow read: if isAuth();
      allow write: if false; // Cloud Functions only (Admin SDK bypasses rules)
    }

    match /wantToTry/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid in request.resource.data.users;
      allow update, delete: if isAuth() && request.auth.uid in resource.data.users;
    }
  }
}
